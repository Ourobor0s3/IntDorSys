@inherits LayoutComponentBase
@inject AuthSession Auth
@inject NavigationManager Navigation

<div class="app-shell">
    @if (!Auth.IsLoggedIn)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="text-muted mt-2">Loading...</div>
        </div>
    }
    else
    {
        <nav class="app-nav">
            <div class="app-nav__brand">IntDorSys</div>
            <button type="button" class="btn btn-sm btn-outline-secondary app-nav__menu" @onclick="ToggleMenu">Menu</button>
            <div class="navbar-nav gap-2 flex-row flex-wrap @( _menuOpen ? "app-nav__links--open" : "app-nav__links")">
                <NavLink class="nav-link" href="/home">Overview</NavLink>
                <NavLink class="nav-link" href="/user-info">Users</NavLink>
                <NavLink class="nav-link" href="/laundress">Laundress</NavLink>
                <NavLink class="nav-link" href="/reports">Reports</NavLink>
            </div>
            <button type="button" class="btn btn-sm btn-outline-danger ms-auto" disabled="@_loggingOut" @onclick="Logout">
                @if (_loggingOut)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                }
                else
                {
                    <text>Logout</text>
                }
            </button>
        </nav>
    }

    <main class="app-content">@Body</main>
</div>

@code {
    private bool _menuOpen;
    private bool _loggingOut;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task Logout()
    {
        if (_loggingOut) return;
        
        _loggingOut = true;
        await InvokeAsync(StateHasChanged);

        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}