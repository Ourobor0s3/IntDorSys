@page "/overview"
@page "/home"
@inject ApiClient Api
@inherits AuthorizedPageBase

<div class="page-header">
    <h1 class="page-title">Overview</h1>
    <span class="text-muted">@DateTime.Today.ToString("d MMMM yyyy")</span>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else if (_initialLoad)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-header">
                    <span>Today</span>
                    <span class="badge bg-primary ms-2">@_todayModels.Count</span>
                </div>
                <div class="card-body p-2">
                    @if (_todayModels.Count == 0)
                    {
                        <div class="text-muted small">No records today.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-1">
                            @foreach (var item in _todayModels.OrderBy(x => x.TimeWash))
                            {
                                <div class="laund-item">
                                    <span class="laund-item__time">@item.TimeWash.ToString("HH:mm")</span>
                                    <span class="laund-item__user">@GetUserName(item.SelectUser)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-header">Analytics</div>
                <div class="card-body">
                    @if (_points.Count == 0)
                    {
                        <div class="text-muted small">No analytics yet.</div>
                    }
                    else
                    {
                        <div class="overview-legend mb-3">
                            <span class="me-3"><i class="legend-dot legend-dot--a"></i> All records</span>
                            <span><i class="legend-dot legend-dot--b"></i> Used</span>
                        </div>
                        <div class="overview-bars">
                            @foreach (var item in _points)
                            {
                                var max = Math.Max(1, MaxValue);
                                var a = Math.Max(2, (int)Math.Round((double)item.Value1 / max * 100));
                                var b = Math.Max(2, (int)Math.Round((double)item.Value2 / max * 100));

                                <div class="overview-bar-row">
                                    <div class="overview-bar-label" title="@item.Name">@item.Name</div>
                                    <div class="overview-bar-track">
                                        <div class="overview-bar overview-bar--a" style="width: @a%">@item.Value1</div>
                                        <div class="overview-bar overview-bar--b" style="width: @b%">@item.Value2</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LaundressViewModel> _todayModels = new();
    private List<ChartPoint> _points = new();
    private bool _initialLoad = true;
    private string? _error;
    private int MaxValue => _points.Count == 0 ? 1 : _points.SelectMany(p => new[] { p.Value1, p.Value2 }).Max();
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate = DateTime.Today.AddDays(1);

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (!Auth.IsLoggedIn)
        {
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _error = null;
        _todayModels = new List<LaundressViewModel>();
        _points = new List<ChartPoint>();
        _initialLoad = false;

        try
        {
            var laundressTask = Api.GetLaundressAsync(_startDate, _endDate, CancellationToken.None);
            var analyticsTask = Api.GetAnalyticsAsync(CancellationToken.None);

            await Task.WhenAll(laundressTask, analyticsTask);

            var laundress = await laundressTask;
            if (laundress?.Data != null)
            {
                var today = _startDate.ToString("dd.MM.yyyy");
                var todayDay = laundress.Data.FirstOrDefault(d => d.Date == today);
                if (todayDay?.LaundModels is { } models)
                {
                    _todayModels = new List<LaundressViewModel>(models);
                }
            }

            var analytics = await analyticsTask;
            if (analytics?.Data != null)
            {
                _points = new List<ChartPoint>(analytics.Data);
            }

            _error = laundress?.Errors.FirstOrDefault()?.Message ?? analytics?.Errors.FirstOrDefault()?.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string GetUserName(UserInfoViewModel? user)
    {
        if (user == null) return "—";
        return string.IsNullOrWhiteSpace(user.FullName) ? user.Username : $"{user.FullName}";
    }
}