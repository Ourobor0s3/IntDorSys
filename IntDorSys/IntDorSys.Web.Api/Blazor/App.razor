@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(false))" />
</head>

<body>
<Routes @rendermode="@(new InteractiveServerRenderMode(false))" />
<script>
    window.__storage = {
        get: function (k) { return localStorage.getItem(k); },
        set: function (k, v) { localStorage.setItem(k, v); },
        remove: function (k) { localStorage.removeItem(k); }
    };
    window.__cookie = {
        get: function (k) {
            var m = document.cookie.match('(^|;)\\s*' + k + '\\s*=\\s*([^;]+)');
            return m ? decodeURIComponent(m[2]) : null;
        },
        set: function (k, v, days) {
            var d = new Date();
            d.setTime(d.getTime() + (days || 30) * 86400000);
            document.cookie = k + '=' + encodeURIComponent(v) + ';path=/;expires=' + d.toUTCString() + ';SameSite=Lax';
        },
        remove: function (k) {
            document.cookie = k + '=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT;SameSite=Lax';
        }
    };
    window.__initAuth = {
        token: '@HttpContextAccessor.HttpContext?.Request.Cookies["auth_token"]',
        role: '@HttpContextAccessor.HttpContext?.Request.Cookies["user_role"]'
    };
    window.__getInitAuth = function () { return window.__initAuth; };
    window.__clearInitAuth = function () { window.__initAuth = null; };
</script>
<script src="_framework/blazor.web.js"></script>
</body>
</html>
