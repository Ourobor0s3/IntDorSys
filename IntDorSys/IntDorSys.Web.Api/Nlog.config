<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      throwExceptions="false"
      internalLogFile="/tmp/nlog-internal.log"
      internalLogLevel="Warn">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <variable name="DirectoryLogs" value="${environment:LOG_DIR}" />
  <variable name="DefaultLayout"
            value="${longdate} ${level:uppercase=true} ${ndlc}${newline}${logger:shortName=true} ${message}${when:when='${exception}' != '':inner='${newline}  ${exception:format=tostring}'}"
  />

  <targets>
    <!-- Основной файл логов -->
    <target name="file" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Логи ASP.NET Core -->
    <target name="file-aspnetcore" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.aspnetcore.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Логи Entity Framework -->
    <target name="file-ef" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.ef.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Логи сервисов -->
    <target name="file-services" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.services.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Логи апи запросов и ответов -->
    <target name="file-http" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.http.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Логи планировщика -->
    <target name="file-scheduler" xsi:type="File"
            layout="${DefaultLayout}"
            fileName="${DirectoryLogs}/${shortdate}.scheduler.txt"
            maxArchiveDays="5"
            maxArchiveFiles="4"
            archiveNumbering="Sequence"
            archiveAboveSize="52428800"
            keepFileOpen="false"
            encoding="utf-8" />

    <!-- Вывод в stdout — для docker logs -->
    <target name="console" xsi:type="Console" layout="${DefaultLayout}" />
  </targets>

  <!-- Локальный конфиг для переопределения настроек -->
  <include file="nlog.local.config" ignoreErrors="true" />
  <!-- Note: include is case-sensitive on Linux; rename to NLog.local.config if needed -->

  <rules>
    <!-- ASP.NET Core (Warn+ → file, ignore Debug/Trace) -->
    <logger name="Microsoft.AspNetCore.*" minlevel="Warn" writeTo="file-aspnetcore,console" final="true" />
    <logger name="Microsoft.AspNetCore.*" maxlevel="Info" final="true" />

    <!-- Entity Framework (Info+ → file + console, ignore Debug/Trace) -->
    <logger name="Microsoft.EntityFrameworkCore.*" minlevel="Info" writeTo="file-ef,console" final="true" />
    <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Debug" final="true" />

    <!-- Сервисы -->
    <logger name="IntDorSys.Services.*" minlevel="Info" writeTo="file-services,console" final="true" />
    <logger name="IntDorSys.Laundress.Services.Services.*" minlevel="Info" writeTo="file-services,console" final="true" />
    <logger name="IntDorSys.TelegramBot.*" minlevel="Info" writeTo="file-services,console" final="true" />

    <!-- Scheduler -->
    <logger name="IntDorSys.Laundress.Services.Jobs.*" minlevel="Info" writeTo="file-scheduler,console" final="true" />

    <!-- Microsoft.Extensions / Quartz / Jobs — игнорировать Debug/Trace -->
    <logger name="Microsoft.Extensions.*" minlevel="Trace" final="true" />
    <logger name="Quartz.*" minlevel="Trace" final="true" />
    <logger name="*.Jobs.*" minlevel="Trace" final="true" />

    <!-- Все остальные логи (включая приложение) — только в файл -->
    <logger name="*" minlevel="Trace" writeTo="file" />
  </rules>
</nlog>