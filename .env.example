# PostgreSQL
POSTGRES_PASSWORD=admin

# Telegram (Battle mode used when BuildTest=false)
TELEGRAM_TEST_TOKEN=your_test_bot_token
TELEGRAM_BATTLE_TOKEN=your_battle_bot_token

# Admin IDs
ADMIN_CHAT_ID=0
MANAGER_LAUNDRESS_ID=0

# JWT (min 32 chars / 256 bits for HS256)
JWT_SECRET=00000000-0000-0000-0000-000000000000

# Connection strings
DB_HOST=db
DB_PORT=5432
DB_NAME=dorm
DB_USER=postgres
DB_PASSWORD=admin

# Mode
BUILD_TEST=false
ASPNETCORE_ENVIRONMENT=Development

# Ports
BACKEND_PORT=5050
FRONTEND_PORT=4201
DB_PORT_HOST=5433

# Allowed CORS origins (for production set your domain)
CORS_ORIGIN_1=http://localhost:4201
CORS_ORIGIN_2=http://localhost:5050

# URLs (set to your domain in production, e.g. https://your-domain.com)
FRONT_URL=http://localhost:4201
BACK_URL=http://localhost:5050

# GitHub Container Registry (для пуша frontend образа)
GHCR_USER=ourobor0s3
