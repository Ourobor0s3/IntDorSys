root = true
# Editor configuration, see http://editorconfig.org

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
max_line_length = 120
guidelines = 100, 120
ij_visual_guides = 100, 120
insert_final_newline = false
indent_size = 4

# ReSharper inspection severities
resharper_enforce_do_while_statement_braces_highlighting = error
resharper_enforce_fixed_statement_braces_highlighting = error
resharper_enforce_foreach_statement_braces_highlighting = error
resharper_enforce_for_statement_braces_highlighting = error
resharper_enforce_if_statement_braces_highlighting = error
resharper_enforce_lock_statement_braces_highlighting = error
resharper_enforce_using_statement_braces_highlighting = error
resharper_enforce_while_statement_braces_highlighting = error
resharper_remove_redundant_braces_highlighting = unset

resharper_qualified_using_at_nested_scope = false

# Microsoft .NET properties

csharp_new_line_before_members_in_object_initializers = false
csharp_preferred_modifier_order = required, public, private, protected, internal, new, static, abstract, virtual, sealed, readonly, override, extern, unsafe, volatile, async:error
csharp_style_prefer_utf8_string_literals = true:suggestion
dotnet_naming_rule.constants_rule.import_to_resharper = as_predefined

# STYLECOP Roslynator
roslynator_blank_line_between_single_line_accessors = true
roslynator_blank_line_between_using_directives = never

# TODO
# roslynator_accessor_braces_style = multi_line|single_line_when_expression_is_on_single_line
# roslynator_block_braces_style = multi_line|single_line_when_empty
# roslynator_binary_operator_new_line = after|before
# roslynator_conditional_operator_new_line = after|before
# roslynator_arrow_token_new_line = after|before
# roslynator_new_line_before_while_in_do_statement = true|false
# roslynator_equals_token_new_line = after|before
# roslynator_max_line_length=120
# roslynator_new_line_at_end_of_file = true|false
# roslynator_null_conditional_operator_new_line = after|before
# roslynator_blank_line_after_file_scoped_namespace_declaration = true|false
# roslynator_blank_line_between_switch_sections = include|omit|omit_after_block
# roslynator_array_creation_type_style = explicit|implicit|implicit_when_type_is_obvious
# roslynator_body_style = block|expression
# roslynator_use_block_body_when_declaration_spans_over_multiple_lines = true|false
# roslynator_use_block_body_when_expression_spans_over_multiple_lines = true|false
# roslynator_accessibility_modifiers = explicit|implicit
# roslynator_object_creation_parentheses_style = include|omit
# roslynator_conditional_operator_condition_parentheses_style = include|omit|omit_when_condition_is_single_token
# roslynator.RCS1051.do_not_parenthesize_single_token = true
# roslynator_empty_string_style = field|literal
# roslynator_enum_has_flag_style = method|operator
# roslynator_use_anonymous_function_or_method_group = anonymous_function|method_group
# roslynator_suppress_unity_script_methods = true|false
# roslynator.RCS1246.suppress_when_expression_is_invocation = true|false
# roslynator_null_check_style = equality_operator|pattern_matching
# roslynator_object_creation_type_style = explicit|implicit|implicit_when_type_is_obvious
# roslynator_use_var_instead_of_implicit_object_creation = true|false
# roslynator_infinite_loop_style = for|while
# roslynator_doc_comment_summary_style = multi_line|single_line
# roslynator_enum_flag_value_style = decimal_number|shift_operator

# Naming styles

## pascal_case (PascalCase)
dotnet_naming_style.pascal_case.required_prefix =
dotnet_naming_style.pascal_case.required_suffix =
dotnet_naming_style.pascal_case.word_separator =
dotnet_naming_style.pascal_case.capitalization = pascal_case

## camel_case (camelCase)
dotnet_naming_style.camel_case.required_prefix =
dotnet_naming_style.camel_case.required_suffix =
dotnet_naming_style.camel_case.word_separator =
dotnet_naming_style.camel_case.capitalization = camel_case

## underscore_camel_case (_underscoreCamelCase)
dotnet_naming_style.prefix_camel_case.required_prefix = _
dotnet_naming_style.prefix_camel_case.required_suffix =
dotnet_naming_style.prefix_camel_case.word_separator =
dotnet_naming_style.prefix_camel_case.capitalization = camel_case

# Naming rules

## Interfaces
dotnet_naming_rule.interface_should_be_begins_with_i.severity = error
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = interface_prefix_i
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.interface.required_modifiers =
dotnet_naming_style.interface_prefix_i.required_prefix = I
dotnet_naming_style.interface_prefix_i.required_suffix =
dotnet_naming_style.interface_prefix_i.word_separator =
dotnet_naming_style.interface_prefix_i.capitalization = pascal_case

## Types: class, struct, delegate, interface, enum and namespaces
dotnet_naming_rule.types_should_be_pascal_case.severity = error
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case
dotnet_naming_symbols.types.applicable_kinds = class, struct, delegate, interface, enum, namespace
dotnet_naming_symbols.types.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.types.required_modifiers =

## Events or methods
dotnet_naming_rule.event_or_method_should_be_pascal_case.severity = error
dotnet_naming_rule.event_or_method_should_be_pascal_case.symbols = event_or_method
dotnet_naming_rule.event_or_method_should_be_pascal_case.style = pascal_case
dotnet_naming_symbols.event_or_method.applicable_kinds = event, method
dotnet_naming_symbols.event_or_method.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.event_or_method.required_modifiers =

## Properties
dotnet_naming_rule.property_should_be_pascal_case.severity = warning
dotnet_naming_rule.property_should_be_pascal_case.symbols = property
dotnet_naming_rule.property_should_be_pascal_case.style = pascal_case
dotnet_naming_symbols.property.applicable_kinds = property
dotnet_naming_symbols.property.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.property.required_modifiers =

## Public or protected fields
dotnet_naming_rule.public_or_protected_field_should_be_camelcase.severity = error
dotnet_naming_rule.public_or_protected_field_should_be_camelcase.symbols = public_or_protected_field
dotnet_naming_rule.public_or_protected_field_should_be_camelcase.style = pascal_case
dotnet_naming_symbols.public_or_protected_field.applicable_kinds = field
dotnet_naming_symbols.public_or_protected_field.applicable_accessibilities = public, protected
dotnet_naming_symbols.public_or_protected_field.required_modifiers =

## Private or internal fields
dotnet_naming_rule.private_or_internal_field_should_be_camelcase.severity = error
dotnet_naming_rule.private_or_internal_field_should_be_camelcase.symbols = private_or_internal_field
dotnet_naming_rule.private_or_internal_field_should_be_camelcase.style = prefix_camel_case
dotnet_naming_symbols.private_or_internal_field.applicable_kinds = field
dotnet_naming_symbols.private_or_internal_field.applicable_accessibilities = internal, private, private_protected
dotnet_naming_symbols.private_or_internal_field.required_modifiers =

## Private or internal readonly fields
dotnet_naming_rule.static_readonly_field_should_be_camelcase.severity = error
dotnet_naming_rule.static_readonly_field_should_be_camelcase.symbols = private_or_internal_static_readonly_field
dotnet_naming_rule.static_readonly_field_should_be_camelcase.style = prefix_camel_case
dotnet_naming_symbols.private_or_internal_static_readonly_field.applicable_kinds = field
dotnet_naming_symbols.private_or_internal_static_readonly_field.resharper_applicable_kinds = readonly_field
dotnet_naming_symbols.private_or_internal_static_readonly_field.applicable_accessibilities = internal, private, private_protected
dotnet_naming_symbols.private_or_internal_static_readonly_field.required_modifiers = static, readonly
dotnet_naming_symbols.private_or_internal_static_readonly_field.resharper_required_modifiers = static

## Local variables or constants
dotnet_naming_rule.local_variable_or_constant_should_be_camel_case.severity = error
dotnet_naming_rule.local_variable_or_constant_should_be_camel_case.symbols = local_member
dotnet_naming_rule.local_variable_or_constant_should_be_camel_case.style = camel_case
dotnet_naming_symbols.local_member.applicable_kinds = local, local_function
dotnet_naming_symbols.local_member.applicable_accessibilities =
dotnet_naming_symbols.local_member.required_modifiers =

# Microsoft .NET properties

## var vs explicit type definition
csharp_style_prefer_utf8_string_literals = true:suggestion
csharp_style_var_elsewhere = true:error
csharp_style_var_for_built_in_types = true:error
csharp_style_var_when_type_is_apparent = true:error
csharp_using_directive_placement = outside_namespace:error

## Private constants
dotnet_naming_rule.constants_rule.severity = error
dotnet_naming_rule.constants_rule.style = camel_case
dotnet_naming_rule.constants_rule.symbols = constants_symbols
dotnet_naming_symbols.constants_symbols.applicable_accessibilities = private_protected, private
dotnet_naming_symbols.constants_symbols.applicable_kinds = field
dotnet_naming_symbols.constants_symbols.required_modifiers = const

## Public constants
dotnet_naming_rule.public_constants_rule.severity = error
dotnet_naming_rule.public_constants_rule.style = pascal_case
dotnet_naming_rule.public_constants_rule.symbols = public_constants_symbols
dotnet_naming_symbols.public_constants_symbols.applicable_accessibilities = public, internal, protected, protected_internal
dotnet_naming_symbols.public_constants_symbols.applicable_kinds = field
dotnet_naming_symbols.public_constants_symbols.required_modifiers = const

## Parentheses
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:silent
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion

## Predefined type
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Qualification: "this", class type
dotnet_style_qualification_for_event = false:error
dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error

# .NET Coding Convention

## Organize usings
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = true

# Expression-level preferences
dotnet_style_coalesce_expression = true:warning
dotnet_style_collection_initializer = true:suggestion
dotnet_style_namespace_match_folder = true:error
dotnet_style_null_propagation = true
dotnet_style_operator_placement_when_wrapping = beginning_of_line
dotnet_style_prefer_inferred_anonymous_type_member_names = true:warning
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:warning
dotnet_style_prefer_simplified_interpolation = true:suggestion

## Field preferences
dotnet_style_readonly_field = true:suggestion

# ReSharper properties
resharper_braces_for_for = required_for_multiline
resharper_braces_for_foreach = required_for_multiline
resharper_braces_for_ifelse = required_for_multiline
resharper_braces_for_while = required_for_multiline
resharper_max_initializer_elements_on_line = 1

[*.{json,xml,yaml,yml,html,resx,csproj,config,ruleset}]
indent_size = 2